{
    "action": {
        "default_icon": {
            "128": "/icons/iconbig.png",
            "16": "/icons/iconsmall.png",
            "32": "/icons/icon.png",
            "48": "/icons/iconmed.png"
        },
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "js": ["js/content_script.js"],
            "matches": ["\u003Call_urls>"],
            "run_at": "document_idle"
        }
    ],
    "description": "Capture bugs and notes during exploratory testing.",
    "icons": {
        "128": "/icons/iconbig.png",
        "16": "/icons/iconsmall.png",
        "32": "/icons/icon.png",
        "48": "/icons/iconmed.png"
    },

    "manifest_version": 3,
    "name": "QA Companion",
    "permissions": [
        "storage",
        "tabs",
        "activeTab",
        "downloads",
        "scripting",
        "notifications",
        "unlimitedStorage"
    ],

    "version": "1.0",
    "web_accessible_resources": [
        {
            "matches": ["\u003Call_urls>"],
            "resources": [
                "js/annotation_editor.html",
                "js/annotation_editor.js"
            ]
        }
    ]
}
